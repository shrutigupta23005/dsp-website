# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/delhi_shoe_palace?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/delhi_shoe_palace?schema=public"

# ─── Auth.js ──────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Resend (Email) ──────────────────────────────────────────
RESEND_API_KEY="re_your-resend-api-key"

# ─── Google Analytics ─────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ─── Store Configuration ─────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER="919999999999"           # Format: country code + number, no + or spaces
NEXT_PUBLIC_STORE_ADDRESS="Delhi Shoe Palace, Karol Bagh, New Delhi, India"
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL="https://www.google.com/maps/embed?pb=your-embed-url"

# ─── Phase 6: Integrations ───────────────────────────────────

# reCAPTCHA v3 (get from https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=                                  # Google reCAPTCHA v3 site key (public)
RECAPTCHA_SECRET_KEY=                                # Google reCAPTCHA v3 secret key (server)

# Sentry (get from https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=                              # Sentry DSN URL
SENTRY_ORG=                                          # Sentry organization slug
SENTRY_PROJECT=                                      # Sentry project slug

# Social Media
NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/delhishoepalace"
NEXT_PUBLIC_FACEBOOK_URL="https://facebook.com/delhishoepalace"
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=                      # Google Maps review URL
NEXT_PUBLIC_GOOGLE_MAPS_URL="https://maps.google.com"

# Site
NEXT_PUBLIC_SITE_DOMAIN="delhishoepalace.com"        # e.g., delhishoepalace.com
NEXT_PUBLIC_SITE_URL="https://delhishoepalace.com"   # Full URL with protocol
GOOGLE_SITE_VERIFICATION=                            # Google Search Console verify token
